1) //stack using arrays
#include<iostream>
using namespace std;
int main()
{
	int s[10],size,item,top=-1,op,i;
	cout<<"enter size of the stack";
	cin>>size;
	do
	{
		cout<<"\n1:PUSH\n2:POP\n3:PEEK\n4:DISPLAY\n5:EXIT\nCHOOSE";
		cin>>op;
		switch(op)
		{
			case 1:if(top==size-1)
			       cout<<"stack is overflow";
			       else
			       {
			       	top=top+1;
			       	cout<<"\n enter stack element:";
			       	cin>>item;
			       	s[top]=item;
				   }
				   break;
		    case 2:if(top==-1)
			       cout<<"stack is underflow";
				   else
				   {
				   	cout<<s[top]<<"is popped";
				   	top=top-1;
				   }
				   break;
		    case 3:if(top==-1)
			       cout<<"stack is underflow";
				   else
				   {
				   	cout<<s[top]<<"is top element";
				   }
				   break;
			case 4:if(top==-1)
			       cout<<"stack is underflow";
				   else
				   {
				   	for(i=top;i>=0;i--)
				   	cout<<s[i]<<" ";
				   }
				   break;
			case 5:exit(0);
			default:cout<<"do you want to continue 1/0";
			cin>>op;	   	   		   		   
		}
		while(op);
	}

2) //stack using linked list
#include<iostream>
using namespace std;
int main()
class node
{
	public:
		int data;
		node*link;
};
int main()
{
	node*top=NULL,*cn=NULL,*t=NULL;
	int val,op;
	do
	{
		cout<<"\n1:PUSH\n2:POP\n3:PEEK\n4:DISPLAY\n5:EXIT\nCHOOSE ANY OPTION";
		cin>>op;
		switch(op)
		{
			case 1:cn=new node();
			       cout<<"\n enter node data";
			       cin>>val;
			       cn->data=val;
			       cn->link=NULL;
			       {
			       	top=cn;
			       	t=cn;
				   }
			       else
			       {
			       	cn->link=t;
			       	top=cn;
			       	t=cn;
				   }
				   break;
		    case 2:if(top==NULL)
			       cout<<"stack is underflow";
				   else
				   {
				   	cout<<top->data<<"is popped";
				   	top=t->link;
				   	t->link=NULL;
				   	delete t;
				   }
				   break;
		    case 3:if(top==NULL)
			       cout<<"stack is underflow";
				   else
				   {
				   	cout<<top->data<<"is top node value";
				   }
				   break;
			case 4:if(top==NULL)
			       cout<<"stack is underflow";
				   else
				   {
				   	t=top;
				   	while(t!=NULL)
				   	{
				   		cout<<t->data<<" ";
				   		t=t->link;
					}
				   }
				   break;
			case 5:exit(0);
			default:cout<<"invalid option";
	    }
	cout<<"do you want continue 1/0";
	cin>>op;	   	   		   		   
	}
		while(op);
}

