1) //deque using arrays
#include <iostream>
using namespace std;
#define MAX 10 
int main() {
    int arr[MAX];
    int front = -1, rear = -1;
    int choice, x;

    while (true) {
        cout << "\n--- DEQUE OPERATIONS ---\n";
        cout << "1. Insert Front\n";
        cout << "2. Insert Rear\n";
        cout << "3. Delete Front\n";
        cout << "4. Delete Rear\n";
        cout << "5. Display\n";
        cout << "6. Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        switch (choice) {

        case 1: // Insert Front
            if ((front == 0 && rear == MAX - 1) || (front == rear + 1)) {
                cout << "Deque is Full\n";
            } else {
                cout << "Enter element: ";
                cin >> x;

                if (front == -1) {
                    front = rear = 0;
                } else if (front == 0) {
                    front = MAX - 1;
                } else {
                    front--;
                }
                arr[front] = x;
            }
            break;

        case 2: // Insert Rear
            if ((front == 0 && rear == MAX - 1) || (front == rear + 1)) {
                cout << "Deque is Full\n";
            } else {
                cout << "Enter element: ";
                cin >> x;

                if (front == -1) {
                    front = rear = 0;
                } else if (rear == MAX - 1) {
                    rear = 0;
                } else {
                    rear++;
                }
                arr[rear] = x;
            }
            break;

        case 3: // Delete Front
            if (front == -1) {
                cout << "Deque is Empty\n";
            } else {
                cout << "Deleted element: " << arr[front] << endl;

                if (front == rear) {
                    front = rear = -1;
                } else if (front == MAX - 1) {
                    front = 0;
                } else {
                    front++;
                }
            }
            break;

        case 4: // Delete Rear
            if (front == -1) {
                cout << "Deque is Empty\n";
            } else {
                cout << "Deleted element: " << arr[rear] << endl;

                if (front == rear) {
                    front = rear = -1;
                } else if (rear == 0) {
                    rear = MAX - 1;
                } else {
                    rear--;
                }
            }
            break;

        case 5: // Display
            if (front == -1) {
                cout << "Deque is Empty\n";
            } else {
                cout << "Deque elements: ";
                int i = front;
                while (true) {
                    cout << arr[i] << " ";
                    if (i == rear)
                        break;
                    i = (i + 1) % MAX;
                }
                cout << endl;
            }
            break;

        case 6:
            return 0;

        default:
            cout << "Invalid choice\n";
        }
    }
}

2) //deque using linked list
#include <iostream>
#include <cstdlib>
using namespace std;

class node {
public:
    int data;
    node* ll; // left link
    node* rl; // right link
};

int main() {
    node *f = NULL, *r = NULL, *t = NULL, *cn = NULL;
    int choice, item;

    while (1) {
        cout << "\n--- DEQUE USING LINKED LIST ---\n";
        cout << "1. Insert Front\n";
        cout << "2. Insert Rear\n";
        cout << "3. Delete Front\n";
        cout << "4. Delete Rear\n";
        cout << "5. Display\n";
        cout << "6. Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        switch (choice) {

        case 1: // Insert Front
            cout << "Enter element: ";
            cin >> item;

            cn = new(nothrow) node;
            if (cn == NULL) {
                cout << "Memory allocation failed\n";
                break;
            }

            cn->data = item;
            cn->ll = NULL;
            cn->rl = f;

            if (f == NULL) {
                f = r = cn;
            } else {
                f->ll = cn;
                f = cn;
            }
            break;

        case 2: // Insert Rear
            cout << "Enter element: ";
            cin >> item;

            cn = new(nothrow) node;
            if (cn == NULL) {
                cout << "Memory allocation failed\n";
                break;
            }

            cn->data = item;
            cn->rl = NULL;
            cn->ll = r;

            if (r == NULL) {
                f = r = cn;
            } else {
                r->rl = cn;
                r = cn;
            }
            break;

        case 3: // Delete Front
            if (f == NULL) {
                cout << "Deque is Empty\n";
            } else {
                t = f;
                cout << "Deleted element: " << t->data << endl;

                if (f == r) {
                    f = r = NULL;
                } else {
                    f = f->rl;
                    f->ll = NULL;
                }
                delete t;
            }
            break;

        case 4: // Delete Rear
            if (r == NULL) {
                cout << "Deque is Empty\n";
            } else {
                t = r;
                cout << "Deleted element: " << t->data << endl;

                if (f == r) {
                    f = r = NULL;
                } else {
                    r = r->ll;
                    r->rl = NULL;
                }
                delete t;
            }
            break;

        case 5: // Display
            if (f == NULL) {
                cout << "Deque is Empty\n";
            } else {
                t = f;
                cout << "Deque elements: ";
                while (t != NULL) {
                    cout << t->data << " ";
                    t = t->rl;
                }
                cout << endl;
            }
            break;

        case 6: // Exit
            while (f != NULL) {
                t = f;
                f = f->rl;
                delete t;
            }
            cout << "Exiting...\n";
            return 0;

        default:
            cout << "Invalid choice\n";
        }
    }
}
